# Copier ce fichier en `.env` et renseigner les valeurs :  cp .env.example .env

# --- Requis ---
# Jeton d'accès en lecture TMDB (v4).
# themoviedb.org → compte → Paramètres → API → « Jeton d'accès en lecture (v4) ».
NUXT_TMDB_API_KEY=

# --- Optionnel (défauts sensés, ne surcharger qu'en connaissance de cause) ---
# Chemin du fichier SQLite. Local : ./data/opentvtime.sqlite — Docker : /data/opentvtime.sqlite
# NUXT_DATABASE_PATH=
# Répertoire des migrations Drizzle appliquées au démarrage.
# NUXT_MIGRATIONS_DIR=
# Fuseau horaire de la vue « À venir » (plutôt défini côté Docker).
# TZ=Europe/Paris
